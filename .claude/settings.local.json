  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Projects/RoastMe && npx tsc --noEmit 2>&1 | grep -E 'error TS' | head -10"
          }
        ]
      }
    ]
  }

      "Bash(npx create-next-app@latest . --typescript --tailwind --app --src-dir --no-git --yes 2>&1)",
      "Bash(npx create-next-app@latest . --typescript --tailwind --app --src-dir --no-git -e \"https://github.com/vercel/next.js/tree/canary/examples/hello-world\" 2>&1 | head -5 || true)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm install 2>&1)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm install next@latest 2>&1 | tail -5)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm install eslint-config-next@latest 2>&1 | tail -3)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npx tsc --noEmit 2>&1)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm run build 2>&1)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm run build 2>&1 | tail -20)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm run build 2>&1 | tail -15)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm run dev 2>&1)",
      "Bash(taskkill:*)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npx tsc --noEmit 2>&1 | head -40)",
      "Bash(cd \"C:\\\\Projects\\\\RoastMe\" && npm test 2>&1 | tail -30)",
      "Bash(git diff --name-only HEAD~1 HEAD 2>/dev/null)",
      "Bash(git status --short)",
      "Bash(gh auth:*)"
